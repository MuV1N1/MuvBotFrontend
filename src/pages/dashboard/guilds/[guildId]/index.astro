---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';
import { apiBase } from '../../../../config/public';

const token = Astro.cookies.get('access_token')?.value;
if (!token) return Astro.redirect('/');

const { guildId } = Astro.params;

const [guildRes, setRes] = await Promise.all([
    fetch(`${apiBase}/api/guilds/${guildId}`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch(`${apiBase}/api/guilds/${guildId}/settings`, { headers: { 'Authorization': `Bearer ${token}` } }),
]);
if (guildRes.status === 401) return Astro.redirect('/');
if (!guildRes.ok) return Astro.redirect('/dashboard');

const guild = await guildRes.json();
const settings = await setRes.json();
const welcomeEnabled = settings.welcome?.enabled ?? false;
const quitEnabled = settings.quit?.enabled ?? false;
---

<Layout title="Guild Dashboard">
    <Navbar />
    <main id="guild-dashboard-main" data-guild-id={guildId} class="container mx-auto px-4 py-8 max-w-4xl">
        <div class="flex items-center mb-8 bg-gray-800 p-6 rounded-xl border border-gray-700">
            <img src={guild.iconUrl || 'https://via.placeholder.com/128'} alt="Guild Icon" class="w-20 h-20 rounded-full mr-6 shadow-lg" />
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">{guild.name}</h1>
                <p class="text-gray-400 font-mono text-sm">ID: {guildId}</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- General Module (Always Enabled) -->
            <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 hover:border-purple-500 transition-colors group relative">
                <div class="absolute top-4 right-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Core</span>
                </div>
                <h3 class="text-xl font-bold text-white mb-2">General</h3>
                <p class="text-gray-400 text-sm mb-6">Basic bot configuration like command prefix.</p>
                <a href={`/dashboard/guilds/${guildId}/general`} class="inline-block w-full text-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition-colors">
                    Configure
                </a>
            </div>

            <!-- Welcome Module -->
            <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 hover:border-purple-500 transition-colors">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-xl font-bold text-white">Welcome</h3>
                    <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
                        <input type="checkbox" id="toggle-welcome" data-module="welcome"
                               class="module-toggle toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer"
                               checked={welcomeEnabled} />
                        <label for="toggle-welcome" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-600 cursor-pointer"></label>
                    </div>
                </div>
                <p class="text-gray-400 text-sm mb-6">Greet new members with customizable messages.</p>
                <a href={`/dashboard/guilds/${guildId}/welcome`} id="btn-welcome"
                   class={`inline-block w-full text-center px-4 py-2 rounded-lg transition-colors ${welcomeEnabled ? 'bg-purple-600 text-white hover:bg-purple-700' : 'bg-gray-700 text-gray-400 cursor-not-allowed pointer-events-none'}`}>
                    Configure
                </a>
            </div>

            <!-- Quit Module -->
            <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 hover:border-purple-500 transition-colors">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-xl font-bold text-white">Quit</h3>
                    <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
                        <input type="checkbox" id="toggle-quit" data-module="quit"
                               class="module-toggle toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer"
                               checked={quitEnabled} />
                        <label for="toggle-quit" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-600 cursor-pointer"></label>
                    </div>
                </div>
                <p class="text-gray-400 text-sm mb-6">Send a message when a member leaves the server.</p>
                <a href={`/dashboard/guilds/${guildId}/quit`} id="btn-quit"
                   class={`inline-block w-full text-center px-4 py-2 rounded-lg transition-colors ${quitEnabled ? 'bg-purple-600 text-white hover:bg-purple-700' : 'bg-gray-700 text-gray-400 cursor-not-allowed pointer-events-none'}`}>
                    Configure
                </a>
            </div>
        </div>
    </main>
    <script type="application/json" id="settings-data" set:html={JSON.stringify(settings)} />
</Layout>

<style>
    .toggle-checkbox:checked { right: 0; border-color: #68D391; }
    .toggle-checkbox:checked + .toggle-label { background-color: #68D391; }
    .toggle-checkbox { right: 50%; transition: all 0.3s; }
</style>

<script>
    import { getCookie } from '../../../../utils/auth';
    import { apiBase } from '../../../../config/public';

    const token = getCookie('access_token');
    const guildId = document.getElementById('guild-dashboard-main')!.dataset.guildId!;
    const settings = JSON.parse(document.getElementById('settings-data')!.textContent!);

    document.querySelectorAll<HTMLInputElement>('.module-toggle').forEach(toggle => {
        toggle.addEventListener('change', async () => {
            const moduleName = toggle.dataset.module!;
            const enabled = toggle.checked;
            const btn = document.getElementById(`btn-${moduleName}`);

            settings[moduleName].enabled = enabled;

            try {
                await fetch(`${apiBase}/api/guilds/${guildId}/settings`, {
                    method: 'PUT',
                    headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify(settings)
                });
                if (btn) {
                    if (enabled) {
                        btn.classList.remove('bg-gray-700', 'text-gray-400', 'cursor-not-allowed', 'pointer-events-none');
                        btn.classList.add('bg-purple-600', 'text-white', 'hover:bg-purple-700');
                    } else {
                        btn.classList.add('bg-gray-700', 'text-gray-400', 'cursor-not-allowed', 'pointer-events-none');
                        btn.classList.remove('bg-purple-600', 'text-white', 'hover:bg-purple-700');
                    }
                }
            } catch {
                toggle.checked = !enabled;
                settings[moduleName].enabled = !enabled;
                alert('Failed to save change');
            }
        });
    });
</script>