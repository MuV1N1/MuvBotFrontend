---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';

export const prerender = false;

const {guildId} = Astro.params;
---

<Layout title="Guild Settings">
    <Navbar/>
    <main id="guild-dashboard-main" data-guild-id={guildId} class="container mx-auto px-4 py-8 max-w-5xl">

        <!-- Header skeleton -->
        <div id="header-loading"
             class="animate-pulse flex items-center mb-8 bg-gray-800 p-6 rounded-xl border border-gray-700 h-32">
            <div class="w-20 h-20 bg-gray-700 rounded-full mr-6 shrink-0"></div>
            <div class="h-8 bg-gray-700 w-1/3 rounded"></div>
        </div>

        <!-- Header -->
        <div id="header-content"
             class="hidden flex items-center mb-8 bg-gray-800 p-6 rounded-xl border border-gray-700">
            <img id="guild-icon" src="" alt="Guild Icon" class="w-20 h-20 rounded-full mr-6 shadow-lg shrink-0"/>
            <div>
                <h1 id="guild-name" class="text-3xl font-bold text-white mb-1"></h1>
                <p class="text-gray-400 font-mono text-sm">ID: {guildId}</p>
            </div>
        </div>

        <!-- Search & Category Nav -->
        <div class="mb-8 space-y-4">
            <div class="relative">
                <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 pointer-events-none"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                </svg>
                <input
                        id="search-input"
                        type="text"
                        placeholder="Search plugins..."
                        class="w-full bg-gray-800 border border-gray-700 rounded-xl pl-10 pr-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-colors"
                />
            </div>

            <div class="flex flex-wrap gap-2" id="category-nav">
                <button data-category="all"
                        class="category-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-gray-800 text-gray-400 border-gray-700 hover:bg-gray-700 hover:text-white">
                    All Plugins
                </button>
                <button data-category="essentials"
                        class="category-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-gray-800 text-gray-400 border-gray-700 hover:bg-gray-700 hover:text-white">
                    Essentials
                </button>
                <button data-category="server-management"
                        class="category-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-gray-800 text-gray-400 border-gray-700 hover:bg-gray-700 hover:text-white">
                    Server Management
                </button>
                <button data-category="utilities"
                        class="category-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-gray-800 text-gray-400 border-gray-700 hover:bg-gray-700 hover:text-white">
                    Utilities
                </button>
                <button data-category="social"
                        class="category-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-gray-800 text-gray-400 border-gray-700 hover:bg-gray-700 hover:text-white">
                    Social Alerts
                </button>
                <button data-category="external"
                        class="category-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-gray-800 text-gray-400 border-gray-700 hover:bg-gray-700 hover:text-white">
                    External Integrations
                </button>
            </div>
        </div>

        <!-- Loading state -->
        <div id="loading" class="text-center text-gray-400 py-12 animate-pulse">Loading plugins...</div>

        <!-- Content -->
        <div id="content" class="hidden">
            <div id="module-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            <div id="no-results" class="hidden text-center text-gray-500 py-16">
                <svg class="w-12 h-12 mx-auto mb-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-lg font-medium">No plugins found</p>
                <p class="text-sm mt-1">Try a different search or category</p>
            </div>
        </div>

    </main>
</Layout>


<script>
    import {getCookie} from '../../../../utils/auth';
    import {apiFetch} from '../../../../utils/api';

    const token = getCookie('access_token');
    const guildId = (document.getElementById('guild-dashboard-main') as HTMLElement).dataset.guildId!;

    if (!token) window.location.href = '/';

    type Module = {
        id: string;
        name: string;
        description: string;
        categories: string[];
        badge?: string;
        badgeColor?: string;
        toggleable: boolean;
        href: string;
        enabled?: boolean;
    };

    const MODULES: Module[] = [
        {
            id: 'general',
            name: 'General',
            description: 'Basic bot configuration like command prefix.',
            categories: ['essentials'],
            badge: 'Core',
            badgeColor: 'green',
            toggleable: false,
            href: `/dashboard/guilds/${guildId}/general`,
        },
        {
            id: 'welcome',
            name: 'Welcome',
            description: 'Greet new members with fully customizable messages.',
            categories: ['social', 'essentials'],
            toggleable: true,
            href: `/dashboard/guilds/${guildId}/welcome`,
        },
        {
            id: 'quit',
            name: 'Quit',
            description: 'Send farewell messages when members leave your server.',
            categories: ['social', 'essentials'],
            toggleable: true,
            href: `/dashboard/guilds/${guildId}/quit`,
        },
        {
            id: 'mcWhitelist',
            name: 'Minecraft Whitelist',
            description: 'Integrate your Minecraft server whitelist with Discord roles for seamless access management.',
            categories: ['external'],
            toggleable: true,
            href: `/dashboard/guilds/${guildId}/extensions/mc/whitelist`,
        }
    ];

    let activeCategory = 'all';
    let searchQuery = '';
    let allSettings: any = null;

    function badgeClasses(color?: string) {
        if (color === 'green') return 'bg-green-900/50 text-green-400 border border-green-700/50';
        if (color === 'blue') return 'bg-blue-900/50  text-blue-400  border border-blue-700/50';
        return 'bg-purple-900/50 text-purple-400 border border-purple-700/50';
    }

    function renderCard(mod: Module) {
        const isEnabled = mod.enabled ?? false;
        const btnEnabled = 'bg-purple-600 hover:bg-purple-700 text-white';
        const btnDisabled = 'bg-gray-700 text-gray-500 cursor-not-allowed pointer-events-none';

        return `
            <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 hover:border-purple-500/60 transition-colors group relative flex flex-col">
                ${mod.badge ? `
                <div class="absolute top-4 right-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${badgeClasses(mod.badgeColor)}">${mod.badge}</span>
                </div>` : ''}

                ${mod.toggleable ? `
                <div class="absolute top-4 right-4">
                    <label class="relative inline-flex items-center cursor-pointer" title="${isEnabled ? 'Disable' : 'Enable'}">
                        <input type="checkbox" id="toggle-${mod.id}" class="sr-only peer" ${isEnabled ? 'checked' : ''}>
                        <div class="w-10 h-5 bg-gray-600 peer-checked:bg-purple-600 rounded-full transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                    </label>
                </div>` : ''}

                <h3 class="text-xl font-bold text-white mb-2 pr-16">${mod.name}</h3>
                <p class="text-gray-400 text-sm mb-6 flex-1">${mod.description}</p>

                <a id="btn-${mod.id}" href="${mod.href}"
                   class="inline-block w-full text-center px-4 py-2 rounded-lg font-medium transition-colors ${mod.toggleable && !isEnabled ? btnDisabled : btnEnabled}">
                    Configure
                </a>
            </div>
        `;
    }

    function applyFilter() {
        const grid = document.getElementById('module-grid')!;
        const noResults = document.getElementById('no-results')!;

        const q = searchQuery.toLowerCase();
        const filtered = MODULES.filter(m => {
            const matchesCategory = activeCategory === 'all' || m.categories.includes(activeCategory);
            const matchesSearch = !q || m.name.toLowerCase().includes(q) || m.description.toLowerCase().includes(q);
            return matchesCategory && matchesSearch;
        });

        grid.innerHTML = filtered.map(renderCard).join('');
        noResults.classList.toggle('hidden', filtered.length > 0);

        // Re-attach toggle listeners after re-render
        filtered.filter(m => m.toggleable).forEach(mod => {
            const toggle = document.getElementById(`toggle-${mod.id}`) as HTMLInputElement | null;
            if (toggle) attachToggle(mod, toggle);
        });
    }

    function attachToggle(mod: Module, toggle: HTMLInputElement) {
        toggle.onchange = async (e) => {
            const enabled = (e.target as HTMLInputElement).checked;
            mod.enabled = enabled;
            const btn = document.getElementById(`btn-${mod.id}`);
            if (btn) updateButtonState(btn, enabled);

            if (!allSettings) return;
            allSettings[mod.id] = allSettings[mod.id] ?? {};
            allSettings[mod.id].enabled = enabled;

            try {
                await apiFetch(`/api/guilds/${guildId}/settings`, {
                    method: 'PUT',
                    body: JSON.stringify(allSettings),
                });
            } catch {
                mod.enabled = !enabled;
                toggle.checked = !enabled;
                if (btn) updateButtonState(btn, !enabled);
            }
        };
    }

    function updateButtonState(btn: HTMLElement, enabled: boolean) {
        if (enabled) {
            btn.classList.remove('bg-gray-700', 'text-gray-500', 'cursor-not-allowed', 'pointer-events-none');
            btn.classList.add('bg-purple-600', 'text-white', 'hover:bg-purple-700');
        } else {
            btn.classList.add('bg-gray-700', 'text-gray-500', 'cursor-not-allowed', 'pointer-events-none');
            btn.classList.remove('bg-purple-600', 'text-white', 'hover:bg-purple-700');
        }
    }

    const CAT_ACTIVE = 'bg-purple-600 text-white border-transparent hover:bg-purple-700';
    const CAT_INACTIVE = 'bg-gray-800 text-gray-400 border-gray-700 hover:bg-gray-700 hover:text-white';

    function setActiveCategory(cat: string) {
        activeCategory = cat;
        document.querySelectorAll('.category-btn').forEach(btn => {
            const isActive = (btn as HTMLElement).dataset.category === cat;
            const add = isActive ? CAT_ACTIVE : CAT_INACTIVE;
            const remove = isActive ? CAT_INACTIVE : CAT_ACTIVE;
            remove.split(' ').forEach(c => btn.classList.remove(c));
            add.split(' ').forEach(c => btn.classList.add(c));
        });
        applyFilter();
    }

    // Category nav
    document.querySelectorAll('.category-btn').forEach(btn => {
        btn.addEventListener('click', () => setActiveCategory((btn as HTMLElement).dataset.category!));
    });
    setActiveCategory('all');

    // Search
    document.getElementById('search-input')!.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value;
        applyFilter();
    });

    async function init() {
        try {
            const [guild, settings] = await Promise.all([
                apiFetch(`/api/guilds/${guildId}`),
                apiFetch(`/api/guilds/${guildId}/settings`),
            ]);
            allSettings = settings;

            // Apply enabled state from API to module definitions
            MODULES.forEach(mod => {
                if (mod.toggleable && settings[mod.id] !== undefined) {
                    mod.enabled = settings[mod.id].enabled ?? false;
                }
            });

            // Reveal header
            document.getElementById('header-loading')!.classList.add('hidden');
            const header = document.getElementById('header-content')!;
            header.classList.remove('hidden');
            (header.querySelector('#guild-name') as HTMLElement).textContent = guild.name;
            (header.querySelector('#guild-icon') as HTMLImageElement).src = guild.iconUrl || 'https://via.placeholder.com/128';

            document.getElementById('loading')!.classList.add('hidden');
            document.getElementById('content')!.classList.remove('hidden');
            applyFilter();

        } catch (e) {
            console.error(e);
            window.location.href = '/dashboard';
        }
    }

    init();
</script>
