---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';
import WelcomeModule from '../../../../components/modules/WelcomeModule.astro';
import { apiBase } from '../../../../config/public';

const token = Astro.cookies.get('access_token')?.value;
if (!token) return Astro.redirect('/');

const { guildId } = Astro.params;

const [setRes, channelRes, roleRes] = await Promise.all([
    fetch(`${apiBase}/api/guilds/${guildId}/settings`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch(`${apiBase}/api/guilds/${guildId}/channels`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch(`${apiBase}/api/guilds/${guildId}/roles`, { headers: { 'Authorization': `Bearer ${token}` } }),
]);
if (setRes.status === 401) return Astro.redirect('/');

const settings = await setRes.json();
const channels = await channelRes.json();
const roles = await roleRes.json();
---

<Layout title="Welcome Settings">
    <Navbar />
    <main id="guild-welcome-main" data-guild-id={guildId} class="container mx-auto px-4 py-8 max-w-4xl">
        <a href={`/dashboard/guilds/${guildId}`} class="text-gray-400 hover:text-white mb-6 inline-flex items-center">
            &larr; Back to Modules
        </a>
        <h1 class="text-3xl font-bold text-white mb-8">Welcome Settings</h1>
        <form id="settings-form" class="space-y-6">
            <WelcomeModule settings={settings.welcome} channels={channels} roles={roles} />
            <div class="flex justify-end pt-4">
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-bold rounded-lg shadow-lg">
                    Save Changes
                </button>
            </div>
        </form>
    </main>
    <script type="application/json" id="settings-data" set:html={JSON.stringify(settings)} />
    <script type="application/json" id="channels-data" set:html={JSON.stringify(channels)} />
    <script type="application/json" id="roles-data" set:html={JSON.stringify(roles)} />
</Layout>

<script>
    import { getCookie } from '../../../../utils/auth';
    import { apiBase } from '../../../../config/public';

    const token = getCookie('access_token');
    const guildId = document.getElementById('guild-welcome-main')!.dataset.guildId!;
    const settings = JSON.parse(document.getElementById('settings-data')!.textContent!);
    const channels = JSON.parse(document.getElementById('channels-data')!.textContent!);
    const roles = JSON.parse(document.getElementById('roles-data')!.textContent!);
    const form = document.getElementById('settings-form') as HTMLFormElement;
    const aiToggle = document.getElementById('toggle-ai-messages') as HTMLInputElement;
    const roleOnJoinToggle = document.getElementById('toggle-role') as HTMLInputElement;

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        settings.welcome.message = formData.get('welcome-message') as string;
        settings.welcome.aiEnabled = aiToggle.checked;
        settings.welcome.aiPrompt = formData.get('welcome-ai-prompt') as string;
        settings.welcome.roleOnJoinEnabled = roleOnJoinToggle.checked;

        const selectedChannelId = formData.get('welcome-channel') as string;
        if (selectedChannelId && selectedChannelId !== 'Select a channel') {
            settings.welcome.channelId = selectedChannelId;
            const ch = channels.find((c: any) => c.id === selectedChannelId);
            if (ch) settings.welcome.channelName = ch.name;
        }
        const selectedRoleId = formData.get('welcome-role') as string;
        if (selectedRoleId && selectedRoleId !== 'Select a role') {
            settings.welcome.roleOnJoinId = selectedRoleId;
            const r = roles.find((r: any) => r.id === selectedRoleId);
            if (r) settings.welcome.roleOnJoinName = r.name;
        }

        const res = await fetch(`${apiBase}/api/guilds/${guildId}/settings`, {
            method: 'PUT',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify(settings)
        });
        if (res.ok) alert('Saved!');
        else alert('Error saving.');
    });
</script>