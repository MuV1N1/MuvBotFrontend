---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';
import QuitModule from "../../../../components/modules/QuitModule.astro";

export const prerender = false;
const {guildId} = Astro.params;
---

<Layout title="Quit Settings">
    <Navbar/>
    <main id="guild-quit-main" data-guild-id={guildId} class="container mx-auto px-4 py-8 max-w-4xl">
        <a href={`/dashboard/guilds/${guildId}`} class="text-gray-400 hover:text-white mb-6 inline-flex items-center">
            &larr; Back to Modules
        </a>

        <h1 class="text-3xl font-bold text-white mb-8">Quit Settings</h1>

        <div id="loading" class="text-center text-gray-400">Loading...</div>

        <div id="content" class="hidden">
            <form id="settings-form" class="space-y-6">
                <QuitModule/>

                <div class="flex justify-end pt-4">
                    <button type="submit"
                            class="px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-bold rounded-lg shadow-lg">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </main>
</Layout>

<script>
    import { getCookie } from '../../../../utils/auth';
    import { apiBase } from '../../../../config/public';

    const token = getCookie('access_token');
    const guildId = (document.getElementById('guild-quit-main') as HTMLElement).dataset.guildId!;

    if (!token) window.location.href = '/';

    async function init() {
        try {
            const headers = { 'Authorization': `Bearer ${token}` };
            const [setRes, channelRes] = await Promise.all([
                fetch(`${apiBase}/api/guilds/${guildId}/settings`, { headers }),
                fetch(`${apiBase}/api/guilds/${guildId}/channels`, { headers }),
            ]);

            const [settings, channels] = await Promise.all([setRes.json(), channelRes.json()]);

            const form = document.getElementById('settings-form') as HTMLFormElement;
            (form.querySelector('[name="quit-message"]') as HTMLTextAreaElement).value = settings.quit.message || '';

            const mod = (window as any).quitModule;
            mod.initChannels(settings.quit.channelIds ?? [], channels);

            document.getElementById('loading')!.classList.add('hidden');
            document.getElementById('content')!.classList.remove('hidden');

            form.onsubmit = async (e) => {
                e.preventDefault();
                const formData = new FormData(form);

                settings.quit.message = formData.get('quit-message');
                settings.quit.channelIds = mod.getChannelIds();

                const res = await fetch(`${apiBase}/api/guilds/${guildId}/settings`, {
                    method: 'PUT',
                    headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify(settings),
                });

                if (res.ok) alert('Saved!');
                else alert('Error saving.');
            };

        } catch (e) {
            console.error(e);
            window.location.href = `/dashboard/guilds/${guildId}`;
        }
    }
    init();
</script>
