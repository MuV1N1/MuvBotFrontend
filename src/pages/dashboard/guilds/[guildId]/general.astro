---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';
import GeneralModule from '../../../../components/modules/GeneralModule.astro';

export const prerender = false;
const { guildId } = Astro.params;
---

<Layout title="General Settings">
    <Navbar />
    <main id="guild-general-main" data-guild-id={guildId} class="container mx-auto px-4 py-8 max-w-4xl">
        <a href={`/dashboard/guilds/${guildId}`} class="text-gray-400 hover:text-white mb-6 inline-flex items-center">
            &larr; Back to Modules
        </a>
        
        <h1 class="text-3xl font-bold text-white mb-8">General Settings</h1>

        <div id="loading" class="text-center text-gray-400">Loading...</div>

        <div id="content" class="hidden">
            <form id="settings-form" class="space-y-6">
                 <!-- Reuse Component -->
                 <GeneralModule />

                 <div class="flex justify-end pt-4">
                    <button type="submit" class="px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-bold rounded-lg shadow-lg">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </main>
</Layout>

<script>
    import { getCookie } from '../../../../utils/auth';
    import { apiBase } from '../../../../config/public';
    const token = getCookie('access_token');
    const guildId = document.getElementById('guild-general-main').dataset.guildId;

    if (!token) window.location.href = '/';

    async function init() {
        try {
            // Fetch Settings
            const setRes = await fetch(`${apiBase}/api/guilds/${guildId}/settings`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const settings = await setRes.json();
            
            // Populate
            const form = document.getElementById('settings-form');
            form.querySelector('[name="commandPrefix"]').value = settings.general.commandPrefix || '!';

            document.getElementById('loading').classList.add('hidden');
            document.getElementById('content').classList.remove('hidden');

            // Save
             form.onsubmit = async (e) => {
                e.preventDefault();
                const formData = new FormData(form);
                
                // We need to preserve other settings! 
                // So we update our local settings object and send it back.
                settings.general.commandPrefix = formData.get('commandPrefix');

                const res = await fetch(`${apiBase}/api/guilds/${guildId}/settings`, {
                    method: 'PUT',
                    headers: { 
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(settings)
                });

                if (res.ok) alert('Saved!');
                else alert('Error saving.');
            };

        } catch (e) {
            console.error(e);
            window.location.href = `/dashboard/guilds/${guildId}`;
        }
    }
    init();
</script>
