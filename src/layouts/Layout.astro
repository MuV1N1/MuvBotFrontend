---
import PerfPanel from '../components/PerfPanel.astro';
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Patch fetch before any module scripts run so all API calls are tracked -->
		<script is:inline>
			window.__perfCalls = [];
			(function () {
				var _orig = window.fetch;
				window.fetch = async function () {
					var args = Array.prototype.slice.call(arguments);
					var url = typeof args[0] === 'string' ? args[0] : (args[0] && args[0].url) || '';
					var t0 = performance.now();
					try {
						var res = await _orig.apply(this, args);
						window.__perfCalls.push({ url: url, ms: Math.round(performance.now() - t0), status: res.status });
						if (window.__perfUpdate) window.__perfUpdate();
						return res;
					} catch (e) {
						window.__perfCalls.push({ url: url, ms: Math.round(performance.now() - t0), status: 0 });
						if (window.__perfUpdate) window.__perfUpdate();
						throw e;
					}
				};
			})();
		</script>
	</head>
	<body class="bg-gray-900 text-white min-h-screen">
		<slot />
		<PerfPanel />
	</body>
</html>

<style is:global>
    /* Custom scrollbar if needed, or base styles */
</style>